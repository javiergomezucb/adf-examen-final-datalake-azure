{
	"name": "dataflow9",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_spl_asignaciones_mensuales",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "silver_spl_afiliaciones",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hecho_spl_asignaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          certificado_id as integer,",
				"          afiliacion_id as integer,",
				"          fecha_emision as date,",
				"          semana_gestacion as integer,",
				"          fecha_probable_parto as date,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          afiliacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          empleador_id as integer,",
				"          caja_id as integer,",
				"          fecha_afiliacion as date,",
				"          nro_matricula as string,",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source1, source2 join(source1@afiliacion_id == source2@afiliacion_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          asignacion_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          empleador_key as integer,",
				"          caja_key as integer,",
				"          monto_bs as decimal(10,2),",
				"          monto_productos as decimal(10,2),",
				"          monto_carnes as decimal(10,2),",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          tipo_subsidio",
				"     )) ~> sink1"
			]
		}
	}
}