{
	"name": "dataflow3",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_spl_empleadores",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_empleador",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          empleador_id as integer,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    empleador_id,\\n    nit,\\n    razon_social,\\n    tipo,\\n    municipio\\nFROM silver.spl_empleadores\\nWHERE empleador_id IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          empleador_key as integer,",
				"          empleador_id as integer,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          municipio as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          empleador_id,",
				"          nit,",
				"          razon_social,",
				"          tipo,",
				"          municipio",
				"     )) ~> sink1"
			]
		}
	}
}