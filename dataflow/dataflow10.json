{
	"name": "dataflow10",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hecho_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          fecha_key as integer,",
				"          ci_beneficiaria as string,",
				"          peso_kg as decimal(6,2),",
				"          productos as string,",
				"          lote as string,",
				"          punto_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    CAST(CONVERT(VARCHAR(8), ea.fecha_entrega, 112) AS INT)  AS fecha_key,\\n    ea.ci_beneficiaria,\\n    ea.peso_kg,\\n    ea.productos,\\n    ea.lote,\\n    ea.punto_entrega\\nFROM silver.spl_entregas_agencia ea\\nWHERE ea.fecha_entrega IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_ag_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          peso_kg as decimal(6,2),",
				"          productos as string,",
				"          lote as string,",
				"          punto_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_key,",
				"          peso_kg,",
				"          productos,",
				"          lote,",
				"          punto_entrega",
				"     )) ~> sink1"
			]
		}
	}
}