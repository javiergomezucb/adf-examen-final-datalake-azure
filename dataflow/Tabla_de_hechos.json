{
	"name": "Tabla_de_hechos",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "gold_hecho_bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_hecho_bja_pagos",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "gold_hecho_spl_asignaciones",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "gold_hecho_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "source5"
				},
				{
					"dataset": {
						"referenceName": "gold_hecho_bja_controles_pediatricos",
						"type": "DatasetReference"
					},
					"name": "source7"
				},
				{
					"dataset": {
						"referenceName": "gold_hecho_spl_entregas_supermercado",
						"type": "DatasetReference"
					},
					"name": "source8"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hecho_subsidios_maestro",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "union1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_pre_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          nro_control as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          pago_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          monto_bs as decimal(10,2),",
				"          concepto_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source(output(",
				"          asignacion_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          empleador_key as integer,",
				"          caja_key as integer,",
				"          monto_bs as decimal(10,2),",
				"          monto_productos as decimal(10,2),",
				"          monto_carnes as decimal(10,2),",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source(output(",
				"          entrega_ag_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          peso_kg as decimal(6,2),",
				"          productos as string,",
				"          lote as string,",
				"          punto_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source5",
				"source(output(",
				"          control_ped_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          nro_control as integer,",
				"          peso_nino_kg as decimal(5,2),",
				"          talla_nino_cm as decimal(5,1),",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source7",
				"source(output(",
				"          entrega_super_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          supermercado_key as integer,",
				"          cantidad_kg as decimal(6,2),",
				"          monto_bs as decimal(10,2),",
				"          tipo_carne as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source8",
				"source7, source2, source3, source4, source5, source8 union(byName: true)~> union1",
				"union1 derive(tipo_evento = case(     !isNull(vacuna_aplicada), 'Control Pediatrico',     !isNull(semana_gestacion), 'Control Prenatal',     !isNull(concepto_pago), 'Pago BJA',     !isNull(tipo_subsidio), 'Asignacion SPL',     !isNull(punto_entrega), 'Entrega Agencia',     !isNull(supermercado_key), 'Entrega Supermercado',     'Desconocido' ),",
				"          fecha_key = iifNull(fecha_key, 19000101)) ~> derivedColumn1",
				"derivedColumn1 filter(!isNull(beneficiaria_key)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          hecho_key as integer,",
				"          fecha_key as integer,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          empleador_key as integer,",
				"          caja_key as integer,",
				"          supermercado_key as integer,",
				"          tipo_evento as string,",
				"          monto_bs as decimal(10,2),",
				"          concepto_pago as string,",
				"          nro_control as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          peso_nino_kg as decimal(5,2),",
				"          talla_nino_cm as decimal(5,1),",
				"          vacuna_aplicada as string,",
				"          monto_productos as decimal(10,2),",
				"          monto_carnes as decimal(10,2),",
				"          tipo_subsidio as string,",
				"          peso_entrega_kg as decimal(6,2),",
				"          lote as string,",
				"          punto_entrega as string,",
				"          tipo_carne as string,",
				"          cantidad_kg as decimal(6,2),",
				"          resultado as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_key,",
				"          beneficiaria_key,",
				"          establecimiento_key,",
				"          empleador_key,",
				"          caja_key,",
				"          supermercado_key,",
				"          tipo_evento,",
				"          monto_bs,",
				"          concepto_pago,",
				"          nro_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          peso_nino_kg,",
				"          talla_nino_cm,",
				"          vacuna_aplicada,",
				"          monto_productos,",
				"          monto_carnes,",
				"          tipo_subsidio,",
				"          lote,",
				"          punto_entrega,",
				"          tipo_carne,",
				"          cantidad_kg,",
				"          resultado,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}